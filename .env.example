# === Required ===
ADMIN_PASSWORD=your_secure_password_here

# === Proxy Settings ===
PROXY_PORT=443
PANEL_PORT=8080
FAKE_TLS_ENABLED=true
FAKE_TLS_SNI=google.com
SECRET_MODE=ee
MAX_CONNECTIONS=1000

# === Telegram Promotion (Optional) ===
TAG=

# === Telegram Bot (Optional) ===
BOT_TOKEN=
ADMIN_CHAT_ID=

# === Advanced ===
LOG_LEVEL=INFO
DATABASE_PATH=/data/phoenix.db
BACKUP_DIR=/data/backups
